{
  "name": "@denna-spec/client",
  "version": "0.1.0",
  "description": "TypeScript library + CLI for loading and validating Denna Spec data files.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "denna": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "commander": "^13.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
